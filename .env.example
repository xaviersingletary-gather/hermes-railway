# ============================================================================
# Hermes on Railway — env var schema for Gather AI's GTM stack
# ============================================================================
# Set these in the Railway dashboard (Service -> Variables) or via:
#   railway variables --set KEY=value
#
# Do NOT commit a real .env. Only this .env.example is in git.
#
# Two categories below:
#   A) Vars that Hermes itself reads natively (LLM providers, runtime).
#   B) Vars that Hermes skills/scripts/MCP tools read at runtime to talk to
#      our GTM stack (HubSpot, Gong, Apollo, etc). These names follow each
#      vendor's standard env convention so any MCP server or custom skill
#      Just Works.
# ============================================================================


# ============================================================================
# A. HERMES CORE
# ============================================================================

# --- LLM provider (required; pick at least one) ---
# OpenRouter is the recommended single-key option (200+ models, swap with `hermes model`).
OPENROUTER_API_KEY=
# Direct provider keys (optional; only set if you want to call the provider directly).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=                  # Gemini via Google AI Studio

# --- Hermes runtime ---
# Hermes' entrypoint remaps its internal user UID at start. Default 10000.
# HERMES_HOME is set to /opt/data inside the image; the Railway volume mounts there.
HERMES_UID=10000
HERMES_GID=10000

# --- Hermes API server (OFF by default; only enable with auth) ---
# API_SERVER_KEY is mandatory if you set HOST. Don't expose without it.
# API_SERVER_HOST=0.0.0.0
# API_SERVER_KEY=


# ============================================================================
# B. GATHER AI GTM STACK
# ============================================================================

# --- HubSpot (CRM, system of record) ---
# Create a Private App in HubSpot, scope to what Hermes needs (contacts, companies,
# deals, engagements, owners, lists). Token starts with `pat-na1-...`.
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=               # numeric, used for building deep links

# --- Slack (messaging gateway for "Rob" + delivery target for enrichment) ---
# Hermes' Slack gateway reads these from config.yaml normally — we set them here
# so any Hermes skill / cron that posts to Slack can also pick them up.
# Create a Slack app at https://api.slack.com/apps; enable Socket Mode for the
# bot, add an App-Level Token with connections:write.
SLACK_BOT_TOKEN=                 # xoxb-...  (Bot User OAuth Token)
SLACK_APP_TOKEN=                 # xapp-...  (App-Level Token, socket mode)
SLACK_SIGNING_SECRET=            # only needed if you also use HTTP events
SLACK_DEFAULT_CHANNEL=           # e.g. #leads, #rob-outreach

# --- Gong (conversation intel; powers post-call automations + deal briefs) ---
# Gong uses Basic Auth with an Access Key + Secret. Create in Gong Admin -> API.
GONG_ACCESS_KEY=
GONG_ACCESS_KEY_SECRET=
GONG_BASE_URL=https://api.gong.io

# --- Apollo (sales intel; cheaper enrichment + sequences) ---
APOLLO_API_KEY=

# --- ZoomInfo (sales intel; deeper firmographics) ---
# ZI uses OAuth2 with a private-key JWT. Three values, plus the cert content.
# If your skills only call HubSpot-routed ZI data, you can skip this.
ZOOMINFO_USERNAME=
ZOOMINFO_CLIENT_ID=
ZOOMINFO_PRIVATE_KEY=            # PEM contents (use Railway's "Multi-line" var input)

# --- SendGrid (outreach email send) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=             # verified sender address

# --- Clay (enrichment & signals) ---
# Clay is push-oriented — typically Clay sends webhooks TO Hermes, not the other way.
# If/when Hermes needs to call back into Clay, set CLAY_API_KEY.
CLAY_WEBHOOK_URL=                # the Hermes endpoint Clay will POST to (set after deploy)
# CLAY_API_KEY=                  # only if you call Clay's HTTP API from Hermes

# --- OpenClaw (your self-hosted agent infra on Hostinger VPS + Tailscale) ---
# Reaching this from Railway requires Tailscale inside the container — defer
# until you actually want Hermes <-> OpenClaw delegation.
# OPENCLAW_API_URL=
# OPENCLAW_API_TOKEN=

# --- CoStar ---
# No general API; manual research workflow. Not configured here.
